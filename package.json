{
	"name": "@jarfajar/ts-workflow-engine",
	"version": "0.0.2",
	"description": "A lightweight, code-first, framework-agnostic workflow and approval engine for Node.js.",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"prisma/schema.prisma",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup && tsc --emitDeclarationOnly",
		"test": "vitest run",
		"prisma:generate": "prisma generate",
		"prisma:push": "prisma db push",
		"demo": "npx tsx example/demo.ts",
		"demo:prisma": "npx tsx example/prisma-demo.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jarfajar2314/ts-workflow-engine.git"
	},
	"keywords": [
		"typescript",
		"workflow",
		"state-machine",
		"approval",
		"engine"
	],
	"author": "jarfajar2314",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^25.9.3",
		"dotenv": "^17.4.2",
		"prisma": "^5.22.0",
		"tsup": "^8.5.1",
		"tsx": "^4.23.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@prisma/client": "^5.22.0"
	}
}
